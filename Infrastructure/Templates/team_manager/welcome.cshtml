@model NotificationWorker.Infrastructure.Templates.TemplatesModels.WelcomeTemplateModel

<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Welcome to Team Manager</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Roboto', Arial, sans-serif;
            background-color: #F0F2F5;
            padding: 32px 16px;
        }

        .wrapper {
            max-width: 600px;
            margin: 0 auto;
        }

        /* ── Top bar ── */
        .topbar {
            background: linear-gradient(135deg, #1A1F36 0%, #2D3561 100%);
            border-radius: 16px 16px 0 0;
            padding: 28px 36px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .topbar-logo {
            width: 36px;
            height: 36px;
        }

        .topbar-name {
            color: #ffffff;
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 0.3px;
        }

        /* ── Hero ── */
        .hero {
            background: linear-gradient(135deg, #2D3561 0%, #4A54A0 100%);
            padding: 48px 36px 36px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero-avatars {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0;
            margin-bottom: 28px;
        }

        .avatar {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            border: 3px solid rgba(255,255,255,0.25);
            background: #3D4880;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-left: -10px;
            flex-shrink: 0;
            overflow: hidden;
        }

        .avatar:first-child { margin-left: 0; }

        .avatar-highlight {
            width: 64px;
            height: 64px;
            border: 3px solid #7B8CDE;
            background: #4A54A0;
            font-size: 24px;
            z-index: 2;
        }

        .hero-title {
            color: #ffffff;
            font-size: 28px;
            font-weight: 700;
            line-height: 1.3;
            margin-bottom: 10px;
        }

        .hero-sub {
            color: rgba(255,255,255,0.70);
            font-size: 15px;
            font-weight: 300;
        }

        /* ── Body card ── */
        .card {
            background: #ffffff;
            padding: 36px;
        }

        .greeting {
            font-size: 17px;
            color: #1A1F36;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .intro {
            font-size: 15px;
            color: #6B7280;
            line-height: 1.7;
            margin-bottom: 28px;
        }

        /* ── Info pills ── */
        .info-grid {
            display: flex;
            gap: 12px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }

        .info-pill {
            flex: 1;
            min-width: 140px;
            background: #F7F8FC;
            border: 1px solid #E5E7EB;
            border-radius: 10px;
            padding: 14px 16px;
        }

        .pill-label {
            font-size: 11px;
            font-weight: 500;
            color: #9CA3AF;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 4px;
        }

        .pill-value {
            font-size: 14px;
            font-weight: 500;
            color: #1A1F36;
        }

        /* ── Discipline icons strip ── */
        .disciplines {
            background: #F7F8FC;
            border-radius: 12px;
            padding: 20px 24px;
            margin-bottom: 28px;
        }

        .disciplines-title {
            font-size: 12px;
            font-weight: 500;
            color: #9CA3AF;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 14px;
        }

        .disciplines-row {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .disc-tag {
            display: flex;
            align-items: center;
            gap: 6px;
            background: #ffffff;
            border: 1px solid #E5E7EB;
            border-radius: 20px;
            padding: 6px 12px;
            font-size: 13px;
            color: #374151;
            font-weight: 400;
        }

        .disc-icon {
            font-size: 14px;
        }

        /* ── CTA ── */
        .cta-wrap {
            text-align: center;
            margin-bottom: 28px;
        }

        .cta-btn {
            display: inline-block;
            background: linear-gradient(135deg, #4A54A0, #6B74C7);
            color: #ffffff !important;
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            padding: 14px 36px;
            border-radius: 8px;
            letter-spacing: 0.2px;
        }

        .cta-hint {
            margin-top: 10px;
            font-size: 12px;
            color: #9CA3AF;
        }

        /* ── Divider ── */
        .divider {
            border: none;
            border-top: 1px solid #F3F4F6;
            margin: 0 0 24px;
        }

        /* ── Quick steps ── */
        .steps-title {
            font-size: 13px;
            font-weight: 500;
            color: #9CA3AF;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 14px;
        }

        .steps {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 28px;
        }

        .step {
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

        .step-num {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #EEF0FB;
            color: #4A54A0;
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .step-text {
            font-size: 14px;
            color: #374151;
            line-height: 1.5;
        }

        .step-text strong {
            color: #1A1F36;
            font-weight: 500;
        }

        /* ── Footer ── */
        .footer {
            background: #F7F8FC;
            border-radius: 0 0 16px 16px;
            padding: 20px 36px;
            text-align: center;
        }

        .footer p {
            font-size: 12px;
            color: #9CA3AF;
            line-height: 1.7;
        }

        .footer a {
            color: #4A54A0;
            text-decoration: none;
        }
    </style>
</head>

<body>
<div class="wrapper">

    <!-- Top bar -->
    <div class="topbar">
        <svg class="topbar-logo" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="36" height="36" rx="8" fill="#4A54A0"/>
            <circle cx="12" cy="14" r="4" fill="#7B8CDE"/>
            <circle cx="24" cy="14" r="4" fill="#A5AEED"/>
            <ellipse cx="12" cy="25" rx="6" ry="4" fill="#7B8CDE"/>
            <ellipse cx="24" cy="25" rx="6" ry="4" fill="#A5AEED"/>
        </svg>
        <span class="topbar-name">Team Manager</span>
    </div>

    <!-- Hero -->
    <div class="hero">
        <div class="hero-avatars">
            <div class="avatar">&#x1F9D1;&#x200D;&#x1F4BB;</div>
            <div class="avatar">&#x1F9D1;&#x200D;&#x1F3A8;</div>
            <div class="avatar avatar-highlight">&#x1F44B;</div>
            <div class="avatar">&#x1F9D1;&#x200D;&#x1F52C;</div>
            <div class="avatar">&#x1F9D1;&#x200D;&#x1F4C8;</div>
        </div>
        <div class="hero-title">Welcome to the team, @Model.Name!</div>
        <div class="hero-sub">You're now part of something great.</div>
    </div>

    <!-- Card body -->
    <div class="card">

        <p class="greeting">Hey @Model.Name,</p>
        <p class="intro">
            Your account is ready. Start collaborating with your team,
            track progress, and ship great work together.
        </p>

        <!-- Info pills -->
        <div class="info-grid">
            <div class="info-pill">
                <div class="pill-label">Email</div>
                <div class="pill-value">@Model.Email</div>
            </div>
            <div class="info-pill">
                <div class="pill-label">Role</div>
                <div class="pill-value">@Model.Role</div>
            </div>
        </div>

        <!-- Disciplines strip -->
        <div class="disciplines">
            <div class="disciplines-title">Built for every discipline</div>
            <div class="disciplines-row">
                <span class="disc-tag"><span class="disc-icon">&#x1F4BB;</span> Engineering</span>
                <span class="disc-tag"><span class="disc-icon">&#x1F3A8;</span> Design</span>
                <span class="disc-tag"><span class="disc-icon">&#x1F4CB;</span> Product</span>
                <span class="disc-tag"><span class="disc-icon">&#x1F4CA;</span> Data</span>
                <span class="disc-tag"><span class="disc-icon">&#x1F4E3;</span> Marketing</span>
                <span class="disc-tag"><span class="disc-icon">&#x2699;&#xFE0F;</span> Ops</span>
            </div>
        </div>

        <!-- CTA -->
        <div class="cta-wrap">
            <a href="@Model.LoginUrl" class="cta-btn">Access your account</a>
            <p class="cta-hint">Opens in your default browser</p>
        </div>

        <hr class="divider"/>

        <!-- Quick steps -->
        <div class="steps-title">Get started in 3 steps</div>
        <div class="steps">
            <div class="step">
                <div class="step-num">1</div>
                <div class="step-text"><strong>Complete your profile</strong> — add a photo and your timezone so your team knows when you're available.</div>
            </div>
            <div class="step">
                <div class="step-num">2</div>
                <div class="step-text"><strong>Join your team board</strong> — see open tasks, ongoing sprints, and who's working on what.</div>
            </div>
            <div class="step">
                <div class="step-num">3</div>
                <div class="step-text"><strong>Say hello</strong> — drop a message in the team channel and introduce yourself.</div>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <div class="footer">
        <p>
            You received this email because an account was created for <strong>@Model.Email</strong>.<br/>
            If this wasn't you, please <a href="#">contact support</a> immediately.<br/><br/>
        </p>
    </div>

</div>
</body>
</html>